#include <algorithm>
#include <cerrno>
#include <cmath>
#include <cstdint>
#include <cstring>
#include <fstream>
#include <iostream>
#include <string>
#include <sys/stat.h>
#include <sys/types.h>
#include <vector>

#include "acl/acl.h"
#include "kernel_operator.h"
#include "kernel_operator_list_tensor_intf.h"

__global__ __vector__ void add_float32_broadcast_case029(GM_ADDR x1, GM_ADDR x2, GM_ADDR z, uint32_t usedCoreNum,
                                                         uint32_t rowsPerCore, uint32_t rowRemainder,
                                                         uint32_t totalTileCount, uint32_t tailTileElementCount);

namespace {
constexpr uint32_t kX1Rows = 64;
constexpr uint32_t kBroadcastBatch = 2;
constexpr uint32_t kRowElementCount = 20481;
constexpr uint32_t kOutputRows = kBroadcastBatch * kX1Rows;

constexpr size_t kX1ElementCount = static_cast<size_t>(kX1Rows) * kRowElementCount;
constexpr size_t kX2ElementCount = static_cast<size_t>(kOutputRows);
constexpr size_t kOutputElementCount = static_cast<size_t>(kOutputRows) * kRowElementCount;

constexpr size_t kX1ByteSize = kX1ElementCount * sizeof(float);
constexpr size_t kX2ByteSize = kX2ElementCount * sizeof(float);
constexpr size_t kOutputByteSize = kOutputElementCount * sizeof(float);

constexpr uint32_t kTileElementCount = 2048;
constexpr uint32_t kScalarBufferElementCount = 8; // 8 float = 32 B
constexpr uint32_t kDoubleBufferCount = 2;
constexpr int32_t kDeviceId = 0;

constexpr float kAbsTol = 1.0e-6f;
constexpr float kRelTol = 1.0e-6f;

constexpr char kInputX1Path[] = "./input/x1.bin";
constexpr char kInputX2Path[] = "./input/x2.bin";
constexpr char kGoldenPath[] = "./output/golden.bin";
constexpr char kOutputPath[] = "./output/output.bin";
constexpr char kOutputDir[] = "./output";

struct LaunchConfig {
    uint32_t usedCoreNum = 1;
    uint32_t rowsPerCore = 1;
    uint32_t rowRemainder = 0;
    uint32_t totalTileCount = 1;
    uint32_t tailTileElementCount = 0;
};

bool CheckAcl(aclError ret, const char *op)
{
    if (ret == ACL_SUCCESS) {
        return true;
    }
    std::cerr << op << " failed, ret = " << ret << std::endl;
    return false;
}

bool EnsureDirectory(const char *path)
{
    struct stat pathStat {};
    if (stat(path, &pathStat) == 0) {
        if (S_ISDIR(pathStat.st_mode)) {
            return true;
        }
        std::cerr << path << " exists but is not a directory." << std::endl;
        return false;
    }

    if (mkdir(path, 0755) == 0 || errno == EEXIST) {
        return true;
    }

    std::cerr << "Failed to create directory " << path << ", errno = " << errno << std::endl;
    return false;
}

bool ReadFloatFile(const char *path, size_t expectedCount, std::vector<float> &buffer)
{
    std::ifstream input(path, std::ios::binary | std::ios::ate);
    if (!input.is_open()) {
        std::cerr << "Failed to open " << path << std::endl;
        return false;
    }

    const std::streamsize expectedBytes = static_cast<std::streamsize>(expectedCount * sizeof(float));
    const std::streamsize fileSize = input.tellg();
    if (fileSize != expectedBytes) {
        std::cerr << path << " size mismatch, expect " << expectedBytes << " bytes, got " << fileSize << " bytes."
                  << std::endl;
        return false;
    }

    buffer.resize(expectedCount);
    input.seekg(0, std::ios::beg);
    input.read(reinterpret_cast<char *>(buffer.data()), expectedBytes);
    if (!input) {
        std::cerr << "Failed to read " << path << std::endl;
        return false;
    }
    return true;
}

bool WriteFloatFile(const char *path, const std::vector<float> &buffer)
{
    std::ofstream output(path, std::ios::binary | std::ios::trunc);
    if (!output.is_open()) {
        std::cerr << "Failed to open " << path << " for write." << std::endl;
        return false;
    }

    output.write(reinterpret_cast<const char *>(buffer.data()),
                 static_cast<std::streamsize>(buffer.size() * sizeof(float)));
    if (!output) {
        std::cerr << "Failed to write " << path << std::endl;
        return false;
    }
    return true;
}

LaunchConfig ComputeLaunchConfig(int32_t deviceId)
{
    LaunchConfig config;

    int64_t availableVectorCores = 8;
#ifdef ACL_DEV_ATTR_VECTOR_CORE_NUM
    const aclError infoRet = aclrtGetDeviceInfo(deviceId, ACL_DEV_ATTR_VECTOR_CORE_NUM, &availableVectorCores);
    if (infoRet != ACL_SUCCESS || availableVectorCores <= 0) {
        std::cerr << "aclrtGetDeviceInfo(ACL_DEV_ATTR_VECTOR_CORE_NUM) failed, fallback to 8 cores." << std::endl;
        availableVectorCores = 8;
    }
#endif

    config.usedCoreNum = std::min<uint32_t>(kOutputRows, static_cast<uint32_t>(availableVectorCores));
    if (kOutputRows <= 8) {
        config.usedCoreNum = 1;
    }
    if (config.usedCoreNum == 0) {
        config.usedCoreNum = 1;
    }

    config.rowsPerCore = kOutputRows / config.usedCoreNum;
    config.rowRemainder = kOutputRows % config.usedCoreNum;
    config.totalTileCount = (kRowElementCount + kTileElementCount - 1U) / kTileElementCount;
    config.tailTileElementCount = kRowElementCount % kTileElementCount;
    return config;
}

bool VerifyOutput(const std::vector<float> &output, const std::vector<float> &golden)
{
    if (output.size() != golden.size()) {
        std::cerr << "Output size mismatch, expect " << golden.size() << ", got " << output.size() << std::endl;
        return false;
    }

    float maxAbsDiff = 0.0f;
    float maxRelDiff = 0.0f;
    size_t firstMismatch = output.size();

    for (size_t i = 0; i < output.size(); ++i) {
        const float absDiff = std::fabs(output[i] - golden[i]);
        const float relDiff = absDiff / std::max(std::fabs(golden[i]), 1.0f);
        maxAbsDiff = std::max(maxAbsDiff, absDiff);
        maxRelDiff = std::max(maxRelDiff, relDiff);

        if (absDiff > (kAbsTol + kRelTol * std::fabs(golden[i]))) {
            firstMismatch = i;
            break;
        }
    }

    if (firstMismatch == output.size()) {
        std::cout << "[Success] verification passed. maxAbsDiff = " << maxAbsDiff
                  << ", maxRelDiff = " << maxRelDiff << std::endl;
        return true;
    }

    const size_t row = firstMismatch / kRowElementCount;
    const size_t col = firstMismatch % kRowElementCount;
    std::cerr << "[Failed] verification failed at linear index " << firstMismatch
              << " (row = " << row << ", col = " << col << "), output = " << output[firstMismatch]
              << ", golden = " << golden[firstMismatch] << ", absDiff = "
              << std::fabs(output[firstMismatch] - golden[firstMismatch]) << std::endl;
    return false;
}

bool RunKernel(const std::vector<float> &x1, const std::vector<float> &x2, std::vector<float> &output)
{
    uint8_t *x1Device = nullptr;
    uint8_t *x2Device = nullptr;
    uint8_t *zDevice = nullptr;
    aclrtStream stream = nullptr;
    bool aclInitialized = false;
    bool deviceSet = false;

    auto cleanup = [&]() {
        if (zDevice != nullptr) {
            aclrtFree(zDevice);
        }
        if (x2Device != nullptr) {
            aclrtFree(x2Device);
        }
        if (x1Device != nullptr) {
            aclrtFree(x1Device);
        }
        if (stream != nullptr) {
            aclrtDestroyStream(stream);
        }
        if (deviceSet) {
            aclrtResetDevice(kDeviceId);
        }
        if (aclInitialized) {
            aclFinalize();
        }
    };

    if (!CheckAcl(aclInit(nullptr), "aclInit")) {
        cleanup();
        return false;
    }
    aclInitialized = true;

    if (!CheckAcl(aclrtSetDevice(kDeviceId), "aclrtSetDevice")) {
        cleanup();
        return false;
    }
    deviceSet = true;

    const LaunchConfig config = ComputeLaunchConfig(kDeviceId);
    std::cout << "Launch config: usedCoreNum = " << config.usedCoreNum
              << ", rowsPerCore = " << config.rowsPerCore
              << ", rowRemainder = " << config.rowRemainder
              << ", totalTileCount = " << config.totalTileCount
              << ", tailTileElementCount = " << config.tailTileElementCount << std::endl;

    if (!CheckAcl(aclrtCreateStream(&stream), "aclrtCreateStream")) {
        cleanup();
        return false;
    }

    if (!CheckAcl(aclrtMalloc(reinterpret_cast<void **>(&x1Device), kX1ByteSize, ACL_MEM_MALLOC_HUGE_FIRST),
                  "aclrtMalloc(x1Device)")) {
        cleanup();
        return false;
    }
    if (!CheckAcl(aclrtMalloc(reinterpret_cast<void **>(&x2Device), kX2ByteSize, ACL_MEM_MALLOC_HUGE_FIRST),
                  "aclrtMalloc(x2Device)")) {
        cleanup();
        return false;
    }
    if (!CheckAcl(aclrtMalloc(reinterpret_cast<void **>(&zDevice), kOutputByteSize, ACL_MEM_MALLOC_HUGE_FIRST),
                  "aclrtMalloc(zDevice)")) {
        cleanup();
        return false;
    }

    if (!CheckAcl(aclrtMemcpy(x1Device, kX1ByteSize, x1.data(), kX1ByteSize, ACL_MEMCPY_HOST_TO_DEVICE),
                  "aclrtMemcpy(x1 H2D)")) {
        cleanup();
        return false;
    }
    if (!CheckAcl(aclrtMemcpy(x2Device, kX2ByteSize, x2.data(), kX2ByteSize, ACL_MEMCPY_HOST_TO_DEVICE),
                  "aclrtMemcpy(x2 H2D)")) {
        cleanup();
        return false;
    }

    add_float32_broadcast_case029<<<config.usedCoreNum, nullptr, stream>>>(
        x1Device, x2Device, zDevice, config.usedCoreNum, config.rowsPerCore, config.rowRemainder,
        config.totalTileCount, config.tailTileElementCount);

    if (!CheckAcl(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream")) {
        cleanup();
        return false;
    }

    output.resize(kOutputElementCount);
    if (!CheckAcl(aclrtMemcpy(output.data(), kOutputByteSize, zDevice, kOutputByteSize, ACL_MEMCPY_DEVICE_TO_HOST),
                  "aclrtMemcpy(z D2H)")) {
        cleanup();
        return false;
    }

    cleanup();
    return true;
}
} // namespace

class KernelAddFloat32BroadcastCase029 {
public:
    __aicore__ inline KernelAddFloat32BroadcastCase029() = default;

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR z, uint32_t usedCoreNum, uint32_t rowsPerCore,
                                uint32_t rowRemainder, uint32_t totalTileCount, uint32_t tailTileElementCount)
    {
        x1Gm.SetGlobalBuffer((__gm__ float *)x1, static_cast<uint32_t>(kX1ElementCount));
        x2Gm.SetGlobalBuffer((__gm__ float *)x2, static_cast<uint32_t>(kX2ElementCount));
        zGm.SetGlobalBuffer((__gm__ float *)z, static_cast<uint32_t>(kOutputElementCount));

        this->usedCoreNum = usedCoreNum;
        this->rowsPerCore = rowsPerCore;
        this->rowRemainder = rowRemainder;
        this->totalTileCount = totalTileCount;
        this->tailTileElementCount = tailTileElementCount;
        this->blockIdx = static_cast<uint32_t>(AscendC::GetBlockIdx());
    }

    __aicore__ inline void Process()
    {
        if (blockIdx >= usedCoreNum) {
            return;
        }

        const uint32_t startRow = blockIdx * rowsPerCore + (blockIdx < rowRemainder ? blockIdx : rowRemainder);
        const uint32_t rowsThisCore = rowsPerCore + (blockIdx < rowRemainder ? 1U : 0U);
        if (rowsThisCore == 0) {
            return;
        }

        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<float> xLocalPing = ubAllocator.Alloc<float, kTileElementCount>();
        AscendC::LocalTensor<float> scalarLocalPing = ubAllocator.Alloc<float, kScalarBufferElementCount>();
        AscendC::LocalTensor<float> broadcastLocalPing = ubAllocator.Alloc<float, kTileElementCount>();
        AscendC::LocalTensor<float> zLocalPing = ubAllocator.Alloc<float, kTileElementCount>();

        AscendC::LocalTensor<float> xLocalPong = ubAllocator.Alloc<float, kTileElementCount>();
        AscendC::LocalTensor<float> scalarLocalPong = ubAllocator.Alloc<float, kScalarBufferElementCount>();
        AscendC::LocalTensor<float> broadcastLocalPong = ubAllocator.Alloc<float, kTileElementCount>();
        AscendC::LocalTensor<float> zLocalPong = ubAllocator.Alloc<float, kTileElementCount>();

        AscendC::DataCopyPadParams dataCopyPadParams {};

        for (uint32_t rowOffset = 0; rowOffset < rowsThisCore; ++rowOffset) {
            const uint32_t outputRow = startRow + rowOffset;
            const uint32_t x1Row = outputRow % kX1Rows;
            const uint32_t x1RowOffset = x1Row * kRowElementCount;
            const uint32_t zRowOffset = outputRow * kRowElementCount;

            AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
            AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID1);

            for (uint32_t tileIdx = 0; tileIdx < totalTileCount; ++tileIdx) {
                const uint32_t eventId = (tileIdx % kDoubleBufferCount == 0) ? EVENT_ID0 : EVENT_ID1;
                const uint32_t tileOffset = tileIdx * kTileElementCount;
                const uint32_t currentElementCount =
                    (tailTileElementCount != 0 && tileIdx == totalTileCount - 1U) ? tailTileElementCount
                                                                                   : kTileElementCount;
                const uint16_t currentByteCount = static_cast<uint16_t>(currentElementCount * sizeof(float));

                AscendC::LocalTensor<float> &xLocal = (tileIdx % kDoubleBufferCount == 0) ? xLocalPing : xLocalPong;
                AscendC::LocalTensor<float> &scalarLocal =
                    (tileIdx % kDoubleBufferCount == 0) ? scalarLocalPing : scalarLocalPong;
                AscendC::LocalTensor<float> &broadcastLocal =
                    (tileIdx % kDoubleBufferCount == 0) ? broadcastLocalPing : broadcastLocalPong;
                AscendC::LocalTensor<float> &zLocal = (tileIdx % kDoubleBufferCount == 0) ? zLocalPing : zLocalPong;

                AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(eventId);
                AscendC::DataCopyPad(xLocal, x1Gm[x1RowOffset + tileOffset], {1, currentByteCount, 0, 0},
                                     dataCopyPadParams);
                AscendC::DataCopyPad(scalarLocal, x2Gm[outputRow], {1, static_cast<uint16_t>(sizeof(float)), 0, 0},
                                     dataCopyPadParams);

                AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(eventId);
                AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(eventId);

                const uint32_t srcShape[] = {1};
                const uint32_t dstShape[] = {currentElementCount};
                AscendC::BroadCast<float, 1, 0>(broadcastLocal, scalarLocal, dstShape, srcShape);
                AscendC::Add(zLocal, xLocal, broadcastLocal, currentElementCount);

                AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(eventId);
                AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(eventId);
                AscendC::DataCopyPad(zGm[zRowOffset + tileOffset], zLocal, {1, currentByteCount, 0, 0});
                AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(eventId);
            }

            AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
            AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID1);
        }
    }

private:
    AscendC::GlobalTensor<float> x1Gm;
    AscendC::GlobalTensor<float> x2Gm;
    AscendC::GlobalTensor<float> zGm;

    uint32_t usedCoreNum = 0;
    uint32_t rowsPerCore = 0;
    uint32_t rowRemainder = 0;
    uint32_t totalTileCount = 0;
    uint32_t tailTileElementCount = 0;
    uint32_t blockIdx = 0;
};

__global__ __vector__ void add_float32_broadcast_case029(GM_ADDR x1, GM_ADDR x2, GM_ADDR z, uint32_t usedCoreNum,
                                                         uint32_t rowsPerCore, uint32_t rowRemainder,
                                                         uint32_t totalTileCount, uint32_t tailTileElementCount)
{
    AscendC::InitSocState();
    KernelAddFloat32BroadcastCase029 kernel;
    kernel.Init(x1, x2, z, usedCoreNum, rowsPerCore, rowRemainder, totalTileCount, tailTileElementCount);
    kernel.Process();
}

int32_t main(int32_t argc, char *argv[])
{
    std::vector<float> x1;
    std::vector<float> x2;
    std::vector<float> golden;
    std::vector<float> output;

    if (!EnsureDirectory(kOutputDir)) {
        return 1;
    }
    if (!ReadFloatFile(kInputX1Path, kX1ElementCount, x1)) {
        return 1;
    }
    if (!ReadFloatFile(kInputX2Path, kX2ElementCount, x2)) {
        return 1;
    }
    if (!ReadFloatFile(kGoldenPath, kOutputElementCount, golden)) {
        return 1;
    }

    if (!RunKernel(x1, x2, output)) {
        return 1;
    }
    if (!WriteFloatFile(kOutputPath, output)) {
        return 1;
    }

    return VerifyOutput(output, golden) ? 0 : 1;
}
