#include <algorithm>
#include <cmath>
#include <cstdint>
#include <filesystem>
#include <fstream>
#include <iomanip>
#include <iostream>
#include <stdexcept>
#include <string>
#include <vector>

#include "acl/acl.h"
#include "kernel_operator.h"
#include "kernel_operator_list_tensor_intf.h"

namespace fs = std::filesystem;

namespace {
constexpr uint32_t X1_DIM0 = 64;
constexpr uint32_t X1_DIM1 = 20481;
constexpr uint32_t X2_DIM0 = 2;
constexpr uint32_t X2_DIM1 = 64;
constexpr uint32_t X2_DIM2 = 1;
constexpr uint32_t OUT_DIM0 = 2;
constexpr uint32_t OUT_DIM1 = 64;
constexpr uint32_t OUT_DIM2 = 20481;

constexpr uint32_t ALIGN_BYTES = 32;
constexpr uint32_t ALIGN_ELEMS = ALIGN_BYTES / sizeof(float);
constexpr uint32_t TILE_BUFFER_BYTES = 24 * 1024;

constexpr size_t X1_ELEM_NUM = static_cast<size_t>(X1_DIM0) * X1_DIM1;
constexpr size_t X2_ELEM_NUM = static_cast<size_t>(X2_DIM0) * X2_DIM1 * X2_DIM2;
constexpr size_t Z_ELEM_NUM = static_cast<size_t>(OUT_DIM0) * OUT_DIM1 * OUT_DIM2;

constexpr size_t X1_BYTES = X1_ELEM_NUM * sizeof(float);
constexpr size_t X2_BYTES = X2_ELEM_NUM * sizeof(float);
constexpr size_t Z_BYTES = Z_ELEM_NUM * sizeof(float);

constexpr double ATOL = 1e-6;
constexpr double RTOL = 1e-6;

inline uint32_t AlignUp(uint32_t value, uint32_t align)
{
    return ((value + align - 1U) / align) * align;
}

inline uint32_t CalcTileLength()
{
    uint32_t tileLen = TILE_BUFFER_BYTES / (sizeof(float) * 3U);
    tileLen = (tileLen / ALIGN_ELEMS) * ALIGN_ELEMS;
    if (tileLen == 0U) {
        tileLen = ALIGN_ELEMS;
    }
    if (tileLen > X1_DIM1) {
        tileLen = AlignUp(X1_DIM1, ALIGN_ELEMS);
    }
    return tileLen;
}

inline void CheckAcl(aclError ret, const char *msg)
{
    if (ret != ACL_SUCCESS) {
        throw std::runtime_error(std::string(msg) + ", aclError=" + std::to_string(static_cast<int>(ret)));
    }
}

std::vector<char> ReadFileStrict(const std::string &path, size_t expectedSize)
{
    std::ifstream ifs(path, std::ios::binary);
    if (!ifs) {
        throw std::runtime_error("failed to open file: " + path);
    }
    ifs.seekg(0, std::ios::end);
    const std::streamsize size = ifs.tellg();
    if (size < 0) {
        throw std::runtime_error("failed to get size: " + path);
    }
    ifs.seekg(0, std::ios::beg);
    if (static_cast<size_t>(size) != expectedSize) {
        throw std::runtime_error(
            "unexpected file size for " + path + ", expected=" + std::to_string(expectedSize) +
            ", actual=" + std::to_string(static_cast<size_t>(size)));
    }
    std::vector<char> buffer(expectedSize);
    if (!ifs.read(buffer.data(), static_cast<std::streamsize>(expectedSize))) {
        throw std::runtime_error("failed to read file: " + path);
    }
    return buffer;
}

void WriteFileStrict(const std::string &path, const void *data, size_t size)
{
    fs::path p(path);
    if (!p.parent_path().empty()) {
        fs::create_directories(p.parent_path());
    }
    std::ofstream ofs(path, std::ios::binary);
    if (!ofs) {
        throw std::runtime_error("failed to open output file: " + path);
    }
    ofs.write(reinterpret_cast<const char *>(data), static_cast<std::streamsize>(size));
    if (!ofs) {
        throw std::runtime_error("failed to write output file: " + path);
    }
}

std::string ResolveInputBin(const std::vector<std::string> &preferred, size_t expectedSize)
{
    for (const auto &path : preferred) {
        if (fs::exists(path) && fs::is_regular_file(path) && fs::file_size(path) == expectedSize) {
            return path;
        }
    }

    std::vector<std::string> candidates;
    const fs::path inputDir("./input");
    if (fs::exists(inputDir) && fs::is_directory(inputDir)) {
        for (const auto &entry : fs::directory_iterator(inputDir)) {
            if (entry.is_regular_file() && entry.path().extension() == ".bin" &&
                entry.file_size() == expectedSize) {
                candidates.push_back(entry.path().string());
            }
        }
    }
    std::sort(candidates.begin(), candidates.end());
    if (!candidates.empty()) {
        return candidates.front();
    }

    throw std::runtime_error("no input bin matched expected size " + std::to_string(expectedSize));
}

bool ValidateOutput(const std::string &outputPath, const std::string &goldenPath)
{
    std::vector<char> outputBytes = ReadFileStrict(outputPath, Z_BYTES);
    std::vector<char> goldenBytes = ReadFileStrict(goldenPath, Z_BYTES);

    const float *output = reinterpret_cast<const float *>(outputBytes.data());
    const float *golden = reinterpret_cast<const float *>(goldenBytes.data());

    size_t mismatchCount = 0;
    double worstAbs = 0.0;
    double worstRel = 0.0;
    size_t worstIndex = 0;

    for (size_t i = 0; i < Z_ELEM_NUM; ++i) {
        const double a = static_cast<double>(output[i]);
        const double b = static_cast<double>(golden[i]);
        const double absDiff = std::abs(a - b);
        const double relDiff = absDiff / std::max(std::abs(b), 1.0);
        const double tol = ATOL + RTOL * std::abs(b);
        if (absDiff > tol) {
            ++mismatchCount;
            if (absDiff > worstAbs) {
                worstAbs = absDiff;
                worstRel = relDiff;
                worstIndex = i;
            }
        }
    }

    if (mismatchCount == 0) {
        std::cout << "compare success" << std::endl;
        return true;
    }

    std::cerr << std::setprecision(10)
              << "compare failed, mismatch_count=" << mismatchCount
              << ", worst_index=" << worstIndex
              << ", output=" << output[worstIndex]
              << ", golden=" << golden[worstIndex]
              << ", max_abs_diff=" << worstAbs
              << ", max_rel_diff=" << worstRel << std::endl;
    return false;
}

class KernelAddFloat32BroadcastCase029 {
public:
    __aicore__ inline KernelAddFloat32BroadcastCase029() {}

    __aicore__ inline void Init(GM_ADDR x1, GM_ADDR x2, GM_ADDR z, uint32_t totalRows, uint32_t cols, uint32_t tileLen)
    {
        totalRows_ = totalRows;
        cols_ = cols;
        tileLen_ = tileLen;
        tileLenAligned_ = AlignUp(tileLen_, ALIGN_ELEMS);

        x1Gm_.SetGlobalBuffer((__gm__ float *)x1, X1_ELEM_NUM);
        x2Gm_.SetGlobalBuffer((__gm__ float *)x2, X2_ELEM_NUM);
        zGm_.SetGlobalBuffer((__gm__ float *)z, Z_ELEM_NUM);

        pipe_.InitBuffer(xBuf_, tileLenAligned_ * sizeof(float));
        pipe_.InitBuffer(yBuf_, tileLenAligned_ * sizeof(float));
        pipe_.InitBuffer(zBuf_, tileLenAligned_ * sizeof(float));
        pipe_.InitBuffer(scalarBuf_, ALIGN_ELEMS * sizeof(float));
    }

    __aicore__ inline void Process()
    {
        const uint32_t blockNum = AscendC::GetBlockNum();
        const uint32_t blockIdx = AscendC::GetBlockIdx();
        if (blockNum == 0U) {
            return;
        }

        AscendC::LocalTensor<float> scalarLocal = scalarBuf_.Get<float>();
        const uint32_t scalarSrcShape[1] = {1U};

        for (uint32_t flatRow = blockIdx; flatRow < totalRows_; flatRow += blockNum) {
            const uint32_t batchIdx = flatRow / X1_DIM0;
            const uint32_t rowIdx = flatRow % X1_DIM0;
            const uint32_t x1Base = rowIdx * cols_;
            const uint32_t x2Index = batchIdx * X2_DIM1 + rowIdx;
            const uint32_t zBase = flatRow * cols_;

            AscendC::DataCopyExtParams scalarCopy = {1, sizeof(float), 0, 0, 0};
            AscendC::DataCopyPadExtParams<float> scalarPad = {
                true, 0, static_cast<uint8_t>(ALIGN_ELEMS - 1U), 0};
            AscendC::DataCopyPad<float>(scalarLocal, x2Gm_[x2Index], scalarCopy, scalarPad);

            for (uint32_t colOffset = 0; colOffset < cols_;) {
                const uint32_t currentLen = std::min(tileLen_, cols_ - colOffset);
                const uint32_t currentAligned = AlignUp(currentLen, ALIGN_ELEMS);

                AscendC::LocalTensor<float> xLocal = xBuf_.Get<float>();
                AscendC::LocalTensor<float> yLocal = yBuf_.Get<float>();
                AscendC::LocalTensor<float> zLocal = zBuf_.Get<float>();

                AscendC::DataCopyExtParams xCopy = {1, currentLen * sizeof(float), 0, 0, 0};
                AscendC::DataCopyPadExtParams<float> xPad = {
                    true, 0, static_cast<uint8_t>(currentAligned - currentLen), 0};
                AscendC::DataCopyPad<float>(xLocal, x1Gm_[x1Base + colOffset], xCopy, xPad);

                const uint32_t broadcastDstShape[1] = {currentLen};
                AscendC::BroadCast<float, 1, 0>(yLocal, scalarLocal, broadcastDstShape, scalarSrcShape);
                AscendC::Add(zLocal, xLocal, yLocal, currentLen);

                AscendC::DataCopyExtParams zCopy = {1, currentLen * sizeof(float), 0, 0, 0};
                AscendC::DataCopyPad<float>(zGm_[zBase + colOffset], zLocal, zCopy);

                colOffset += currentLen;
            }
        }
    }

private:
    AscendC::TPipe pipe_;
    AscendC::TBuf<AscendC::TPosition::VECIN> xBuf_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> yBuf_;
    AscendC::TBuf<AscendC::TPosition::VECOUT> zBuf_;
    AscendC::TBuf<AscendC::TPosition::VECCALC> scalarBuf_;
    AscendC::GlobalTensor<float> x1Gm_;
    AscendC::GlobalTensor<float> x2Gm_;
    AscendC::GlobalTensor<float> zGm_;
    uint32_t totalRows_;
    uint32_t cols_;
    uint32_t tileLen_;
    uint32_t tileLenAligned_;
};

} // namespace

__global__ __vector__ void add_float32_broadcast_case029(
    GM_ADDR x1, GM_ADDR x2, GM_ADDR z, uint32_t totalRows, uint32_t cols, uint32_t tileLen)
{
    AscendC::InitSocState();
    KernelAddFloat32BroadcastCase029 kernel;
    kernel.Init(x1, x2, z, totalRows, cols, tileLen);
    kernel.Process();
}

int main(int argc, char *argv[])
{
    (void)argc;
    (void)argv;

    void *x1Device = nullptr;
    void *x2Device = nullptr;
    void *zDevice = nullptr;
    aclrtStream stream = nullptr;
    int32_t deviceId = 0;
    bool aclInitialized = false;
    bool deviceSet = false;

    try {
        const std::string x1Path = ResolveInputBin(
            {"./input/x1.bin", "./input/input_x1.bin", "./input/input_x.bin"}, X1_BYTES);
        const std::string x2Path = ResolveInputBin(
            {"./input/x2.bin", "./input/input_x2.bin", "./input/input_y.bin"}, X2_BYTES);
        const std::string outputPath = "./output/output.bin";
        const std::string goldenPath = "./output/golden.bin";

        std::vector<char> x1Host = ReadFileStrict(x1Path, X1_BYTES);
        std::vector<char> x2Host = ReadFileStrict(x2Path, X2_BYTES);
        std::vector<char> zHost(Z_BYTES, 0);

        CheckAcl(aclInit(nullptr), "aclInit failed");
        aclInitialized = true;

        CheckAcl(aclrtSetDevice(deviceId), "aclrtSetDevice failed");
        deviceSet = true;

        CheckAcl(aclrtCreateStream(&stream), "aclrtCreateStream failed");

        CheckAcl(aclrtMalloc(&x1Device, X1_BYTES, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc x1 failed");
        CheckAcl(aclrtMalloc(&x2Device, X2_BYTES, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc x2 failed");
        CheckAcl(aclrtMalloc(&zDevice, Z_BYTES, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc z failed");

        CheckAcl(aclrtMemcpy(x1Device, X1_BYTES, x1Host.data(), X1_BYTES, ACL_MEMCPY_HOST_TO_DEVICE),
                 "aclrtMemcpy x1 failed");
        CheckAcl(aclrtMemcpy(x2Device, X2_BYTES, x2Host.data(), X2_BYTES, ACL_MEMCPY_HOST_TO_DEVICE),
                 "aclrtMemcpy x2 failed");

        const uint32_t totalRows = OUT_DIM0 * OUT_DIM1;
        const uint32_t tileLen = CalcTileLength();
        const uint32_t numBlocks = totalRows;

        add_float32_broadcast_case029<<<numBlocks, nullptr, stream>>>(
            x1Device, x2Device, zDevice, totalRows, OUT_DIM2, tileLen);
        CheckAcl(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream failed");

        CheckAcl(aclrtMemcpy(zHost.data(), Z_BYTES, zDevice, Z_BYTES, ACL_MEMCPY_DEVICE_TO_HOST),
                 "aclrtMemcpy z failed");

        WriteFileStrict(outputPath, zHost.data(), Z_BYTES);

        const bool pass = ValidateOutput(outputPath, goldenPath);

        if (zDevice != nullptr) {
            (void)aclrtFree(zDevice);
            zDevice = nullptr;
        }
        if (x2Device != nullptr) {
            (void)aclrtFree(x2Device);
            x2Device = nullptr;
        }
        if (x1Device != nullptr) {
            (void)aclrtFree(x1Device);
            x1Device = nullptr;
        }
        if (stream != nullptr) {
            (void)aclrtDestroyStream(stream);
            stream = nullptr;
        }
        if (deviceSet) {
            (void)aclrtResetDevice(deviceId);
            deviceSet = false;
        }
        if (aclInitialized) {
            (void)aclFinalize();
            aclInitialized = false;
        }

        return pass ? 0 : 1;
    } catch (const std::exception &e) {
        std::cerr << e.what() << std::endl;

        if (zDevice != nullptr) {
            (void)aclrtFree(zDevice);
        }
        if (x2Device != nullptr) {
            (void)aclrtFree(x2Device);
        }
        if (x1Device != nullptr) {
            (void)aclrtFree(x1Device);
        }
        if (stream != nullptr) {
            (void)aclrtDestroyStream(stream);
        }
        if (deviceSet) {
            (void)aclrtResetDevice(deviceId);
        }
        if (aclInitialized) {
            (void)aclFinalize();
        }
        return 1;
    }
}
